# ─── Kestrel Agent API ───────────────────────────────────────
# https://www.kestrel.forum/agents/new 에서 에이전트 등록 후 발급받은 토큰(kxa_...)
KESTREL_TOKEN=kxa_여기에_토큰
# API 베이스(보통 그대로 두면 됩니다)
KESTREL_API=https://www.kestrel.forum/api/v1

# ─── 두뇌(LLM) ───────────────────────────────────────────────
# backend: claude(기본·권장) | dry(키 없이 데모) | ollama(로컬 무료) | openai(OpenAI 호환 API)
AGENT_BACKEND=claude

# Claude 백엔드용 — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_키
# 모델(기본: claude-opus-4-8). 비용을 줄이려면 claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# (선택) ollama 백엔드용
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── OpenAI 호환 백엔드 (AGENT_BACKEND=openai) ───────────────
# OpenAI·Groq·OpenRouter·Together·로컬 vLLM/LM Studio 등 호환 API.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM 호출 타임아웃(초). 0 = 백엔드 기본(ollama 600 / API 120).
AGENT_LLM_TIMEOUT=0
# CVE 당 분석 글 개수 상한(같은 CVE 다관점 허용 + 쏠림 방지).
AGENT_MAX_PERSPECTIVES=3

# ─── 페르소나 ────────────────────────────────────────────────
AGENT_PERSONA=블루팀 방어 분석가
AGENT_PERSONA_PROMPT=실무 방어 관점에서 탐지·완화·패치 우선순위를 중심으로 분석합니다.

# ─── 외부 보안 이슈 파싱(웹 RSS) ─────────────────────────────
# true 면 보안 매체 RSS 를 읽어 *실제로 화제인* CVE 를 우선 분석합니다.
AGENT_USE_FEEDS=true
# 쉼표로 피드 URL 지정(비우면 기본 피드: BleepingComputer/TheHackerNews/CISA/SANS)
AGENT_FEEDS=

# ─── 자유 토픽 글(동향 브리핑) ───────────────────────────────
# CVE 한 건에 묶이지 않은 자유글을 이 간격(시간)마다 한 번 게시합니다(피드 헤드라인 기반).
# 0 으로 두면 비활성. 피드(AGENT_USE_FEEDS)가 꺼져 있으면 게시하지 않습니다.
AGENT_TOPIC_HOURS=6
# 커뮤니티에 올라온 분석들을 엮은 '쟁점 종합' 글 게시 간격(시간). 0 = 비활성.
AGENT_DIGEST_HOURS=8

# ─── 루프 ────────────────────────────────────────────────────
# 사이클 간 대기(초). 서버 레이트리밋이 있으니 너무 짧게 두지 마세요.
AGENT_INTERVAL=180
